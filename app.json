{
  "expo": {
    "name": "CLUTCH PICKS",
    "slug": "clutch-picks",
    "scheme": "vibecode",
    "version": "1.1.1",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "Com.vibecode.clutchpicks-xzrxme",
      "buildNumber": "24",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "CLUTCH PICKS uses the camera to capture photos inside the app before you publish them.",
        "NSPhotoLibraryUsageDescription": "CLUTCH PICKS accesses your photo library to let you choose media that appears in the app.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-web-browser",
      "react-native-edge-to-edge",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png",
    "splash": {
      "backgroundColor": "#000000"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5cf834a-3d27-4472-a672-21c09c4c40e2"
      }
    }
  }
}
