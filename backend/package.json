{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "worker": "bun run src/worker.ts",
    "worker-dev": "bun run --hot src/worker.ts",
    "studio": "cloud-studio --port 3001 --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "release:check": "bun run src/scripts/releaseReadiness.ts",
    "backtest:simulation": "bun run src/scripts/simulationBacktest.ts",
    "backtest:historical-current": "bun run src/scripts/currentEngineHistoricalReplay.ts",
    "release:check:production": "railway run --environment production --service clutch-picks -- bun run release:check",
    "qa:predictions:live": "bun run src/scripts/predictionInvariantSweep.ts",
    "qa:predictions:production": "PREDICTION_SWEEP_BASE_URL=https://clutch-picks-production.up.railway.app bun run qa:predictions:live",
    "qa:sources:live": "bun run src/scripts/predictionSourceCoverageAudit.ts",
    "qa:sources:production": "railway run --environment production --service clutch-picks -- bun run qa:sources:live"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^13.1.3",
    "prisma": "6",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@better-auth/expo": "^1.4.18",
    "@hono/node-server": "1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "6",
    "@sentry/bun": "^10.50.0",
    "better-auth": "^1.5.5",
    "hono": "4.6.0",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^5.9.6",
    "lru-cache": "^11.2.6",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "resend": "^6.12.3",
    "rss-parser": "^3.13.0",
    "zod": "4.1.11"
  }
}
