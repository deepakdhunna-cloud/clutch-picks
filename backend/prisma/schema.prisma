generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  bio           String?
  isPrivate     Boolean    @default(false)
  role          String     @default("user")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  accounts      Account[]
  picks         UserPick[]
  followers     Follow[]   @relation("UserFollowing")
  following     Follow[]   @relation("UserFollowers")
  discussionPosts    DiscussionPost[]
  discussionLikes    DiscussionLike[]
  discussionComments DiscussionComment[]
  conversationsAsParticipant1 Conversation[] @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[] @relation("ConversationParticipant2")
  sentMessages Message[] @relation("MessageSender")
  pushTokens   PushToken[]
}

model UserPick {
  id         String    @id @default(cuid())
  odId       String
  gameId     String
  pickedTeam String    // "home" or "away"
  result     String?   // "win", "loss", or null if game not finished
  // Enriched at settlement time so the UI can render Signature Calls without
  // having to cross-reference a separate games list. All nullable: existing
  // picks stay null until the backfill script populates them; new picks get
  // populated when the resolver settles them.
  modelPredictedWinner String?  // "home" | "away" — what the model picked
  modelConfidence      Int?     // 50-95
  modelHomeWinProb     Int?     // 0-100, raw home win probability
  finalHomeScore       Int?
  finalAwayScore       Int?
  homeTeam   String?   // home team abbreviation (e.g. "LAL")
  awayTeam   String?   // away team abbreviation (e.g. "BOS")
  sport      String?   // sport/league (e.g. "NBA")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [odId], references: [id], onDelete: Cascade)

  @@unique([odId, gameId]) // One pick per user per game
  @@index([odId, createdAt])
  @@index([gameId])
  @@index([result])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// User follows
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Discussion posts
model DiscussionPost {
  id        String   @id @default(cuid())
  userId    String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     DiscussionLike[]
  comments  DiscussionComment[]

  @@index([userId])
  @@index([createdAt])
}

model DiscussionLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model DiscussionComment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// Player News for confidence fluctuation
model PlayerNews {
  id         String   @id @default(cuid())
  playerId   String
  playerName String
  teamId     String
  sport      String
  headline   String
  content    String
  sentiment  String   // "positive", "negative", "neutral"
  impact     Int      // 1-10 scale of impact on confidence
  createdAt  DateTime @default(now())

  @@index([teamId])
  @@index([sport])
  @@index([createdAt])
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  participant1 User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant1Id String
  participant2 User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  participant2Id String
  messages     Message[]
  @@unique([participant1Id, participant2Id])
}

model Message {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId       String
  content        String
  readAt         DateTime?

  @@index([conversationId, createdAt])
  @@index([conversationId, senderId, readAt])
}

// Team follows (user follows a specific team)
model TeamFollow {
  id               String   @id @default(cuid())
  userId           String
  teamId           String   // ESPN team ID
  teamName         String
  teamAbbreviation String
  sport            String   // e.g. "NBA", "NFL"
  createdAt        DateTime @default(now())

  @@unique([userId, teamId])
  @@index([userId])
}

model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "pick_resolved", "new_follower", "new_message"
  title     String
  body      String
  data      String?  // JSON string for navigation params
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model EloRating {
  id          String   @id  // format: "{sport}-{teamId}"
  teamId      String
  sport       String
  rating      Float    @default(1500)
  lastUpdated DateTime @default(now())

  @@unique([sport, teamId])
}

model PredictionResult {
  id               String    @id @default(cuid())
  gameId           String    @unique
  sport            String
  predictedWinner  String
  actualWinner     String?
  confidence       Int
  isTossUp         Boolean   @default(false)
  wasCorrect       Boolean?
  homeElo          Float?
  awayElo          Float?
  homeWinProb      Float?    // 0..1 — needed for Brier score and calibration
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  @@index([sport])
  @@index([wasCorrect])
  @@index([createdAt])
  @@index([sport, wasCorrect])
}

model CalibrationSnapshot {
  id                   String   @id @default(cuid())
  date                 DateTime @default(now())
  league               String   // "NBA", "MLB", etc. or "ALL" for overall
  brierScore           Float
  logLoss              Float
  sampleSize           Int
  reliabilityCurveJson String   // JSON array of { bucket, midpoint, predicted, actual, count }

  @@unique([date, league])
  @@index([league])
  @@index([date])
}
model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    @default("lifetime")
  maxUses     Int       @default(1)
  currentUses Int       @default(0)
  expiresAt   DateTime?
  createdBy   String?
  note        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  redemptions PromoRedemption[]
  @@index([code])
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  redeemedAt  DateTime @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  @@unique([promoCodeId, userId])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("ios") // "ios" or "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "game_live", "big_game", "pick_result", "streak"
  gameId    String?
  title     String
  body      String
  sentAt    DateTime @default(now())
  @@index([userId, sentAt])
  @@index([type, sentAt])
}

