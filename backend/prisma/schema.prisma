generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  bio           String?
  isPrivate     Boolean    @default(false)
  role          String     @default("user")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  accounts      Account[]
  picks         UserPick[]
  followers     Follow[]   @relation("UserFollowing")
  following     Follow[]   @relation("UserFollowers")
  pushTokens   PushToken[]
}

model UserPick {
  id         String    @id @default(cuid())
  odId       String
  gameId     String
  pickedTeam String    // "home" or "away"
  result     String?   // "win", "loss", or null if game not finished
  // Enriched at settlement time so the UI can render Signature Calls without
  // having to cross-reference a separate games list. All nullable: existing
  // picks stay null until the backfill script populates them; new picks get
  // populated when the resolver settles them.
  modelPredictedWinner String?  // "home" | "away" — what the model picked
  modelConfidence      Int?     // 50-95
  modelHomeWinProb     Int?     // 0-100, raw home win probability
  finalHomeScore       Int?
  finalAwayScore       Int?
  homeTeam   String?   // home team abbreviation (e.g. "LAL")
  awayTeam   String?   // away team abbreviation (e.g. "BOS")
  sport      String?   // sport/league (e.g. "NBA")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [odId], references: [id], onDelete: Cascade)

  @@unique([odId, gameId]) // One pick per user per game
  @@index([odId, createdAt])
  @@index([gameId])
  @@index([result])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// User follows
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Player News for confidence fluctuation
model PlayerNews {
  id         String   @id @default(cuid())
  playerId   String
  playerName String
  teamId     String
  sport      String
  headline   String
  content    String
  sentiment  String   // "positive", "negative", "neutral"
  impact     Int      // 1-10 scale of impact on confidence
  createdAt  DateTime @default(now())

  @@index([teamId])
  @@index([sport])
  @@index([createdAt])
}

// Team follows (user follows a specific team)
model TeamFollow {
  id               String   @id @default(cuid())
  userId           String
  teamId           String   // ESPN team ID
  teamName         String
  teamAbbreviation String
  sport            String   // e.g. "NBA", "NFL"
  createdAt        DateTime @default(now())

  @@unique([userId, teamId])
  @@index([userId])
}

model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "pick_resolved", "new_follower", "new_message"
  title     String
  body      String
  data      String?  // JSON string for navigation params
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model EloRating {
  id          String   @id  // format: "{sport}-{teamId}"
  teamId      String
  sport       String
  rating      Float    @default(1500)
  lastUpdated DateTime @default(now())

  @@unique([sport, teamId])
}

model PredictionResult {
  id               String    @id @default(cuid())
  gameId           String    @unique
  sport            String
  predictedWinner  String
  actualWinner     String?
  confidence       Int
  isTossUp         Boolean   @default(false)
  wasCorrect       Boolean?
  homeElo          Float?
  awayElo          Float?
  homeWinProb      Float?    // 0..1 — needed for Brier score and calibration
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  @@index([sport])
  @@index([wasCorrect])
  @@index([createdAt])
  @@index([sport, wasCorrect])
}

model CalibrationSnapshot {
  id                   String   @id @default(cuid())
  date                 DateTime @default(now())
  league               String   // "NBA", "MLB", etc. or "ALL" for overall
  brierScore           Float
  logLoss              Float
  sampleSize           Int
  reliabilityCurveJson String   // JSON array of { bucket, midpoint, predicted, actual, count }

  @@unique([date, league])
  @@index([league])
  @@index([date])
}
model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    @default("lifetime")
  maxUses     Int       @default(1)
  currentUses Int       @default(0)
  expiresAt   DateTime?
  createdBy   String?
  note        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  redemptions PromoRedemption[]
  @@index([code])
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  redeemedAt  DateTime @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  @@unique([promoCodeId, userId])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("ios") // "ios" or "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "game_live", "big_game", "pick_result", "streak"
  gameId    String?
  title     String
  body      String
  sentAt    DateTime @default(now())
  @@index([userId, sentAt])
  @@index([type, sentAt])
}

// Structured player-availability signals extracted from beat-writer news
// + social. Populated by the 2-min ingestion cron (lib/ingestion/*).
// Distinct from PlayerNews (which keeps the raw article record); this
// table stores the LLM-extracted decision object the prediction engine
// can consume directly. Auto-expires after 48h because injury status
// changes fast and stale rows poison the re-prediction trigger.
model PlayerAvailability {
  id                String   @id @default(cuid())
  playerName        String
  teamId            String   // ESPN team id
  teamAbbreviation  String   // 3-letter NBA code
  sport             String   // "NBA" for pilot; other sports later
  status            String   // out / doubtful / questionable / probable / available / minutes_restriction / game_time_decision
  severity          String   // critical | moderate | minor
  confidence        Float    // LLM's 0..1 confidence in the extraction
  sourceCredibility Float    // 0..1 from sourceRegistry
  gameImpactElo     Int      // estimated Elo swing if the player is OUT
  source            String   // original headline / tweet text (bounded)
  sourceUrl         String?
  reasoning         String   // 1-sentence LLM rationale
  expiresAt         DateTime // now + 48h; cleaned by orchestrator
  supersededById    String?  // set when a newer higher-credibility signal replaces this row
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([teamAbbreviation, sport, createdAt])
  @@index([playerName, sport])
  @@index([expiresAt])
}

// Version history per game — lets the UI render a "prediction timeline"
// showing how Elo / confidence moved as news broke. Every prediction
// gets a v1 "initial" row via shadow.ts; subsequent rows are written by
// the re-predict trigger when a material availability signal lands.
model PredictionVersion {
  id              String   @id @default(cuid())
  gameId          String
  sport           String
  version         Int      // monotonically increasing per gameId (1, 2, 3...)
  homeWinProb     Float
  awayWinProb     Float
  drawProb        Float?
  confidence      Float
  confidenceBand  String
  triggerReason   String   // "initial" | "injury:LeBron James OUT" | "line_movement" | ...
  triggerSourceId String?  // PlayerAvailability.id that caused the re-predict (null for v1)
  factorsJson     String   // JSON.stringify of the factor list at this version
  createdAt       DateTime @default(now())
  @@index([gameId, version])
  @@index([gameId, createdAt])
  @@index([sport, createdAt])
}

// Shadow comparison log — persists old-vs-new engine comparisons to the
// database so they survive Railway redeploys (ephemeral filesystem).
// The JSONL file writes remain as a belt-and-suspenders backup.
model ShadowComparison {
  id                      String   @id @default(cuid())
  gameId                  String
  league                  String
  matchup                 String
  scheduledStart          DateTime
  // Old engine snapshot
  oldPredictedWinner      String
  oldHomeWinProb          Float
  oldConfidence           Float
  // New engine snapshot
  newPredictedWinner      String?  // null = pickem
  newHomeWinProb          Float
  newAwayWinProb          Float
  newDrawProb             Float?
  newConfidence           Float
  newConfidenceBand       String
  unavailableFactorsJson  String   // JSON.stringify of string[]
  // Derived
  agreement               Boolean
  confidenceDelta         Float
  createdAt               DateTime @default(now())

  @@index([gameId])
  @@index([league, createdAt])
  @@index([createdAt])
}

// Time-series of sportsbook lines for each game. Populated by the 30-min
// market-snapshot cron in src/index.ts. Also captured at pick resolution
// with isClosing=true so we can benchmark our pregame picks against the
// closing line (the sharp-accuracy gold standard).
model MarketSnapshot {
  id                String   @id @default(cuid())
  gameId            String
  sport             String
  fetchedAt         DateTime @default(now())
  // Closing-line snapshot taken at game start in resolve-picks.ts.
  isClosing         Boolean  @default(false)
  // Pinnacle de-vigged numbers — our sharp reference. Nullable because
  // Pinnacle isn't always available.
  pinnacleHomeNoVig Float?
  pinnacleAwayNoVig Float?
  pinnacleDrawNoVig Float?
  // Mean across all books (with vig) — always populated when we saved the row.
  avgHomeProb       Float
  avgAwayProb       Float
  // Full MarketLine[] serialized to JSON. Kept as a string for portability
  // (some Prisma setups complain about Json columns on postgres proxies).
  linesJson         String
  @@index([gameId, fetchedAt])
  @@index([sport, fetchedAt])
  @@index([gameId, isClosing])
}

