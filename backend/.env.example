# Server config
PORT=3000
NODE_ENV=development
BACKEND_URL=http://localhost:3000
SERVICE_NAME=web

# Database (PostgreSQL). Example Railway URL:
# postgresql://postgres:<pw>@<host>.railway.app:5432/railway
DATABASE_URL=

# Better Auth session signing secret — any 32+ char random string.
BETTER_AUTH_SECRET=

# OpenAI — AI narrative generation. Optional; analysis falls back to
# factor-driven text when unset.
OPENAI_API_KEY=

# SharpAPI — market consensus lines (Pinnacle + other books). Required in
# production for release; without it the model loses its market calibration
# anchor and the Vegas Market panel is unavailable. Free tier = 12 req/min.
SHARPAPI_KEY=

# SportsDataIO — verified sports data feeds for schedules, rosters, injuries,
# stats, betting lines, matchup stats, and news. Required in production as the
# paid/free-trial data backbone for the prediction engine.
SPORTSDATAIO_API_KEY=

# Calibration admin key — gates POST /api/calibration/run.
CALIBRATION_ADMIN_KEY=

# Beat-writer ingestion pipeline:
#   - APIFY_API_KEY required in production for Twitter/X beat-writer sources
#   - ANTHROPIC_API_KEY unset → Pipeline collects articles but does not
#                               LLM-extract availability signals
#   - INGESTION_ADMIN_KEY unset → /api/ingestion/status falls back to
#                                  CALIBRATION_ADMIN_KEY for gate
APIFY_API_KEY=
ANTHROPIC_API_KEY=
INGESTION_ADMIN_KEY=

# Verified factor-data feeds. Required in production; expected shapes match
# backend/src/lib/data/*.json. The production app points these at the backend
# /api/verified-feeds adapters, which transform trusted public sources.
MLB_UMPIRE_TENDENCY_SOURCE_URL=
SOCCER_MANAGER_CHANGES_SOURCE_URL=
UCL_COEFFICIENTS_SOURCE_URL=
UCL_TEAM_LOCATION_SOURCE_URL=

# RevenueCat — server validation, promo grants, and webhook verification.
REVENUECAT_SECRET_KEY=
REVENUECAT_WEBHOOK_AUTH=

# Resend transactional email — used for OTP delivery.
RESEND_API_KEY=
EMAIL_FROM=noreply@clutchpicksapp.com

# Sentry error tracking.
SENTRY_DSN=

# Persistent upload storage path for profile images. In production this should
# point at a mounted persistent volume, not an ephemeral deploy directory.
UPLOADS_DIR=

# Sign in with Apple token revocation for account deletion.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_ID=

# Operational feature flags / paths.
USE_NEW_PREDICTION_ENGINE=true
LOGS_DIR=
